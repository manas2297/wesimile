rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Shared helpers ────────────────────────────────────────────────────────

    function hasValidTimestamp() {
      return request.resource.data.timestamp == request.time;
    }

    function hasValidMetadata() {
      // userAgent must be a non-empty string; ipAddress must be a non-empty string
      return request.resource.data.userAgent is string &&
             request.resource.data.userAgent.size() > 0 &&
             request.resource.data.ipAddress is string &&
             request.resource.data.ipAddress.size() > 0;
    }

    function validEmail(e) {
      return e is string &&
             e.size() >= 5 &&
             e.size() <= 100 &&
             e.matches('^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$');
    }

    // Phone must be digits-only after normalisation: optional +91 / 0 prefix + 10-digit number
    function validPhone(p) {
      return p is string &&
             p.size() >= 10 &&
             p.size() <= 15 &&
             p.matches('^(\\+91|0)?[6-9][0-9]{9}$');
    }

    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Contact Submissions ────────────────────────────────────────────────────
    match /contactSubmissions/{document} {
      allow create: if
        // Prevent extra fields (exactly the expected keys)
        request.resource.data.keys().hasOnly([
          'name', 'email', 'phone', 'message',
          'timestamp', 'userAgent', 'ipAddress'
        ]) &&

        // Type checks
        request.resource.data.name is string &&
        request.resource.data.message is string &&

        // Length checks (min + max)
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 100 &&
        request.resource.data.message.size() >= 10 &&
        request.resource.data.message.size() <= 1000 &&

        // Format validations
        validEmail(request.resource.data.email) &&
        validPhone(request.resource.data.phone) &&

        // Metadata validations
        hasValidTimestamp() &&
        hasValidMetadata();

      // Only admin users can read and delete submissions
      allow read, delete: if isAdmin();
    }

    // ── B2B Partnerships ───────────────────────────────────────────────────────
    match /b2bPartnerships/{document} {
      allow create: if
        // Prevent extra fields
        request.resource.data.keys().hasOnly([
          'companyName', 'contactName', 'email', 'phone',
          'partnershipType', 'message',
          'timestamp', 'userAgent', 'ipAddress'
        ]) &&

        // Type checks
        request.resource.data.companyName is string &&
        request.resource.data.contactName is string &&
        request.resource.data.partnershipType is string &&
        request.resource.data.message is string &&

        // Length checks (min + max)
        request.resource.data.companyName.size() >= 2 &&
        request.resource.data.companyName.size() <= 100 &&
        request.resource.data.contactName.size() >= 2 &&
        request.resource.data.contactName.size() <= 100 &&
        request.resource.data.partnershipType.size() >= 2 &&
        request.resource.data.partnershipType.size() <= 50 &&
        request.resource.data.message.size() >= 10 &&
        request.resource.data.message.size() <= 1000 &&

        // Format validations
        validEmail(request.resource.data.email) &&
        validPhone(request.resource.data.phone) &&

        // Metadata validations
        hasValidTimestamp() &&
        hasValidMetadata();

      // Only admin users can read and delete B2B submissions
      allow read, delete: if isAdmin();
    }

    // ── Student Applications ───────────────────────────────────────────────────
    match /studentApplications/{document} {
      allow create: if
        // Prevent extra fields
        request.resource.data.keys().hasOnly([
          'fullName', 'email', 'phone', 'school',
          'yearOfStudy', 'specialtyInterest', 'resumeUrl', 'message',
          'timestamp', 'userAgent', 'ipAddress'
        ]) &&

        // Type checks
        request.resource.data.fullName is string &&
        request.resource.data.school is string &&
        request.resource.data.yearOfStudy is string &&
        request.resource.data.specialtyInterest is string &&
        request.resource.data.resumeUrl is string &&
        request.resource.data.message is string &&

        // Length checks (min + max)
        request.resource.data.fullName.size() >= 2 &&
        request.resource.data.fullName.size() <= 100 &&
        request.resource.data.school.size() >= 2 &&
        request.resource.data.school.size() <= 150 &&
        request.resource.data.yearOfStudy.size() >= 2 &&
        request.resource.data.yearOfStudy.size() <= 50 &&
        request.resource.data.specialtyInterest.size() >= 2 &&
        request.resource.data.specialtyInterest.size() <= 50 &&
        request.resource.data.resumeUrl.size() >= 5 &&
        request.resource.data.resumeUrl.size() <= 250 &&
        // Must be a valid https URL
        request.resource.data.resumeUrl.matches('^https://.*') &&
        request.resource.data.message.size() >= 10 &&
        request.resource.data.message.size() <= 1000 &&

        // Format validations
        validEmail(request.resource.data.email) &&
        validPhone(request.resource.data.phone) &&

        // Metadata validations
        hasValidTimestamp() &&
        hasValidMetadata();

      // Only admin users can read and delete student applications
      allow read, delete: if isAdmin();
    }

    // ── Rate Limits ────────────────────────────────────────────────────────────
    match /rateLimits/{document=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // ── Real-Time Chat ──────────────────────────────────────────────────────────
    match /chats/{visitorId} {
      // Admin can read/write any chat; visitors can only read/update their own session
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == visitorId);
      allow create: if request.auth != null && request.auth.uid == visitorId &&
        request.resource.data.keys().hasOnly(['visitorId', 'lastMessage', 'updatedAt', 'status']) &&
        request.resource.data.visitorId is string &&
        request.resource.data.lastMessage is string &&
        request.resource.data.lastMessage.size() <= 500 &&
        request.resource.data.updatedAt == request.time &&
        (!('status' in request.resource.data) || request.resource.data.status in ['active', 'completed', 'deleted']);
      allow update: if isAdmin() || (
        request.auth != null && request.auth.uid == visitorId &&
        request.resource.data.keys().hasOnly(['visitorId', 'lastMessage', 'updatedAt', 'status']) &&
        request.resource.data.lastMessage is string &&
        request.resource.data.lastMessage.size() <= 500 &&
        request.resource.data.updatedAt == request.time &&
        // Ensure visitor cannot modify the status value set by admin
        (
          (!('status' in resource.data) && !('status' in request.resource.data)) ||
          (resource.data.status == request.resource.data.status)
        )
      );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() || (request.auth != null && request.auth.uid == visitorId);
        // Visitors can only create messages, not update or delete
        allow create: if (request.auth != null && request.auth.uid == visitorId &&
          request.resource.data.keys().hasOnly(['text', 'sender', 'timestamp']) &&
          request.resource.data.text is string &&
          request.resource.data.text.size() >= 1 &&
          request.resource.data.text.size() <= 500 &&
          request.resource.data.sender == 'visitor' &&
          request.resource.data.timestamp == request.time
        ) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }
  }
}